# Server
SERVER_PORT=8080
ENVIRONMENT=development

# PostgreSQL DSN
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_DSN=postgres://postgres:postgres@localhost:5432/cbs_simulator?sslmode=disable

# JWT
JWT_SECRET=ganti-dengan-secret-yang-kuat-di-production
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_HOURS=168

# Security
RATE_LIMIT_PER_MINUTE=60
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=30

# PIN Policy
PIN_MIN_LENGTH=6
PIN_MAX_LENGTH=6

# OTP
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
